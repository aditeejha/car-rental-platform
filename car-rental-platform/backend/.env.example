# --- Server ---
NODE_ENV=development
PORT=4000
FRONTEND_ORIGIN=http://localhost:3000

# --- Database (PostgreSQL) ---
DATABASE_URL=postgres://postgres:postgres@localhost:5432/car_rental

# --- Redis ---
REDIS_URL=redis://localhost:6379

# --- Auth ---
JWT_SECRET=replace-me-with-a-long-random-string
JWT_EXPIRES_IN=7d

# --- AWS S3 (image storage) ---
# If you do not have S3, leave AWS_S3_BUCKET empty — the API falls back to
# returning the public Unsplash URL provided by the client.
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=

# --- AI (OpenAI compatible) ---
# Leave OPENAI_API_KEY empty to use the deterministic offline fallback.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# --- Misc ---
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120
